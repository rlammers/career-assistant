{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=CareerAssistant.db"
  },
  "AI": {
    "Provider": "Mock",
    "Model": "gpt-5-mini",
    "BaseUrl": "https://api.openai.com/v1",
    "TimeoutSeconds": 60
  },
  "Authentication": {
    "Enabled": false
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Demo": {
    "Enabled": false,
    "MaxJobs": 100,
    "MaxAnalyses": 200
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "KnownIPNetworks": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
